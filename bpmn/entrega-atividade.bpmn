<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" targetNamespace="http://educlass.com/bpmn" exporter="Camunda Modeler" exporterVersion="5.48.0">
  <collaboration id="Collaboration_EntregaAtividade">
    <participant id="Pool_Estudante" name="Estudante" processRef="Process_Estudante" />
    <participant id="Pool_Sistema" name="Sistema EduClass" processRef="Process_Sistema" />
    <participant id="Pool_Professor" name="Professor" processRef="Process_Professor" />
    <messageFlow id="MF1" sourceRef="Task_VisualizarAtividade" targetRef="Task_ReceberSolicitacao" />
    <messageFlow id="MF2" sourceRef="Task_RegistrarEntrega" targetRef="Task_ReceberNotificacaoEntrega" />
    <messageFlow id="MF3" sourceRef="Task_NotificarEstudante" targetRef="Task_ReceberFeedback" />
  </collaboration>
  <process id="Process_Estudante" isExecutable="false">
    <startEvent id="Start_Estudante" name="Estudante acessa a plataforma" />
    <sequenceFlow id="SF_E1" sourceRef="Start_Estudante" targetRef="Task_VisualizarAtividade" />
    <userTask id="Task_VisualizarAtividade" name="Visualizar atividade disponível" />
    <sequenceFlow id="SF_E2" sourceRef="Task_VisualizarAtividade" targetRef="GW_PrazoAtivo" />
    <exclusiveGateway id="GW_PrazoAtivo" name="Prazo ainda ativo?">
      <outgoing>Flow_12szlk2</outgoing>
    </exclusiveGateway>
    <sequenceFlow id="SF_E3" name="Sim" sourceRef="GW_PrazoAtivo" targetRef="Task_PrepararEntrega" />
    <userTask id="Task_PrepararEntrega" name="Preparar e anexar entrega (arquivo ou texto)" />
    <sequenceFlow id="SF_E5" sourceRef="Task_PrepararEntrega" targetRef="Task_EnviarEntrega" />
    <userTask id="Task_EnviarEntrega" name="Enviar entrega" />
    <sequenceFlow id="SF_E6" sourceRef="Task_EnviarEntrega" targetRef="Task_ReceberConfirmacao" />
    <task id="Task_ReceberConfirmacao" name="Receber confirmação de entrega" />
    <sequenceFlow id="SF_E7" sourceRef="Task_ReceberConfirmacao" targetRef="Task_AguardarCorrecao" />
    <task id="Task_AguardarCorrecao" name="Aguardar correção do professor" />
    <sequenceFlow id="SF_E8" sourceRef="Task_AguardarCorrecao" targetRef="Task_ReceberFeedback" />
    <task id="Task_ReceberFeedback" name="Receber nota e feedback" />
    <sequenceFlow id="SF_E9" sourceRef="Task_ReceberFeedback" targetRef="End_Estudante" />
    <endEvent id="End_Estudante" name="Processo concluído" />
    <sequenceFlow id="Flow_12szlk2" sourceRef="GW_PrazoAtivo" targetRef="End_PrazoEncerrado" />
    <endEvent id="End_PrazoEncerrado" name="Prazo encerrado — entrega não permitida">
      <incoming>Flow_12szlk2</incoming>
    </endEvent>
  </process>
  <process id="Process_Sistema" isExecutable="false">
    <task id="Task_ReceberSolicitacao" name="Receber solicitação de entrega" />
    <serviceTask id="Task_ValidarPrazo" name="Validar prazo da atividade" />
    <serviceTask id="Task_RegistrarEntrega" name="Registrar entrega como PONTUAL" />
    <serviceTask id="Task_RegistrarAtrasada" name="Registrar entrega como ATRASADA" />
    <serviceTask id="Task_EnviarConfirmacao" name="Enviar confirmação ao estudante (data/hora)" />
    <serviceTask id="Task_NotificarProfessor" name="Notificar professor sobre nova entrega" />
    <task id="Task_AguardarAvaliacao" name="Aguardar avaliação do professor" />
    <task id="Task_ReceberNota" name="Receber nota e feedback do professor" />
    <serviceTask id="Task_NotificarEstudante" name="Notificar estudante sobre avaliação" />
    <sequenceFlow id="SF_S1" sourceRef="Task_ReceberSolicitacao" targetRef="Task_ValidarPrazo" />
    <sequenceFlow id="SF_S2" sourceRef="Task_ValidarPrazo" targetRef="GW_DentroPrazo" />
    <sequenceFlow id="SF_S3" name="Sim — status: pontual" sourceRef="GW_DentroPrazo" targetRef="Task_RegistrarEntrega" />
    <sequenceFlow id="SF_S4" name="Não — status: atrasada" sourceRef="GW_DentroPrazo" targetRef="Task_RegistrarAtrasada" />
    <sequenceFlow id="SF_S5" sourceRef="Task_RegistrarEntrega" targetRef="Task_EnviarConfirmacao" />
    <sequenceFlow id="SF_S6" sourceRef="Task_RegistrarAtrasada" targetRef="Task_EnviarConfirmacao" />
    <sequenceFlow id="SF_S7" sourceRef="Task_EnviarConfirmacao" targetRef="Task_NotificarProfessor" />
    <sequenceFlow id="SF_S8" sourceRef="Task_NotificarProfessor" targetRef="Task_AguardarAvaliacao" />
    <sequenceFlow id="SF_S9" sourceRef="Task_AguardarAvaliacao" targetRef="Task_ReceberNota" />
    <sequenceFlow id="SF_S10" sourceRef="Task_ReceberNota" targetRef="Task_NotificarEstudante" />
    <exclusiveGateway id="GW_DentroPrazo" name="Dentro do prazo?" />
  </process>
  <process id="Process_Professor" isExecutable="false">
    <task id="Task_ReceberNotificacaoEntrega" name="Receber notificação de nova entrega" />
    <userTask id="Task_AcessarEntrega" name="Acessar e revisar entrega do estudante" />
    <userTask id="Task_AtribuirNota" name="Atribuir nota e escrever feedback" />
    <serviceTask id="Task_SalvarAvaliacao" name="Salvar avaliação no sistema" />
    <endEvent id="End_Professor" name="Avaliação registrada" />
    <sequenceFlow id="SF_P1" sourceRef="Task_ReceberNotificacaoEntrega" targetRef="Task_AcessarEntrega" />
    <sequenceFlow id="SF_P2" sourceRef="Task_AcessarEntrega" targetRef="Task_AtribuirNota" />
    <sequenceFlow id="SF_P3" sourceRef="Task_AtribuirNota" targetRef="Task_SalvarAvaliacao" />
    <sequenceFlow id="SF_P4" sourceRef="Task_SalvarAvaliacao" targetRef="End_Professor" />
  </process>
