<mxfile host="app.diagrams.net">
  <diagram name="C4 - Nível 1 - Contexto">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="827" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- TÍTULO -->
        <mxCell id="title" value="Diagrama de Contexto – EduClass (C4 Nível 1)" style="text;fontSize=18;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="200" y="20" width="760" height="40" as="geometry"/>
        </mxCell>

        <!-- SISTEMA CENTRAL -->
        <mxCell id="sys" value="&lt;b&gt;EduClass&lt;/b&gt;&lt;br/&gt;[Sistema de Software]&lt;br/&gt;&lt;br/&gt;Plataforma web de gestão de&lt;br/&gt;sala de aula online. Gerencia turmas,&lt;br/&gt;atividades, entregas e avaliações." style="rounded=1;whiteSpace=wrap;fillColor=#1ba1e2;fontColor=#ffffff;strokeColor=#006EAF;fontSize=12;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="430" y="300" width="300" height="140" as="geometry"/>
        </mxCell>

        <!-- ATORES -->
        <mxCell id="u_estudante" value="&lt;b&gt;Estudante&lt;/b&gt;&lt;br/&gt;[Usuário]&lt;br/&gt;&lt;br/&gt;Acessa turmas, visualiza e entrega&lt;br/&gt;atividades, recebe notas." style="shape=mxgraph.c4.person;fillColor=#08427B;fontColor=#ffffff;strokeColor=#073B6F;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="60" y="180" width="200" height="160" as="geometry"/>
        </mxCell>

        <mxCell id="u_professor" value="&lt;b&gt;Professor&lt;/b&gt;&lt;br/&gt;[Usuário]&lt;br/&gt;&lt;br/&gt;Cria turmas, publica atividades,&lt;br/&gt;corrige entregas e dá feedback." style="shape=mxgraph.c4.person;fillColor=#08427B;fontColor=#ffffff;strokeColor=#073B6F;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="900" y="180" width="200" height="160" as="geometry"/>
        </mxCell>

        <mxCell id="u_coordenador" value="&lt;b&gt;Coordenador&lt;/b&gt;&lt;br/&gt;[Usuário]&lt;br/&gt;&lt;br/&gt;Acompanha desempenho geral&lt;br/&gt;das turmas e estudantes." style="shape=mxgraph.c4.person;fillColor=#08427B;fontColor=#ffffff;strokeColor=#073B6F;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="900" y="500" width="200" height="160" as="geometry"/>
        </mxCell>

        <mxCell id="u_admin" value="&lt;b&gt;Administrador&lt;/b&gt;&lt;br/&gt;[Usuário]&lt;br/&gt;&lt;br/&gt;Gerencia usuários e configurações&lt;br/&gt;da plataforma." style="shape=mxgraph.c4.person;fillColor=#08427B;fontColor=#ffffff;strokeColor=#073B6F;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="60" y="500" width="200" height="160" as="geometry"/>
        </mxCell>

        <!-- SISTEMAS EXTERNOS -->
        <mxCell id="ext_email" value="&lt;b&gt;Serviço de E-mail&lt;/b&gt;&lt;br/&gt;[Sistema Externo]&lt;br/&gt;&lt;br/&gt;Envia notificações por e-mail&lt;br/&gt;(ex: SendGrid, SMTP)" style="rounded=1;whiteSpace=wrap;fillColor=#999999;fontColor=#ffffff;strokeColor=#666666;fontSize=11;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="430" y="560" width="300" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="ext_storage" value="&lt;b&gt;Serviço de Armazenamento&lt;/b&gt;&lt;br/&gt;[Sistema Externo]&lt;br/&gt;&lt;br/&gt;Armazena arquivos de entregas&lt;br/&gt;e materiais (ex: AWS S3)" style="rounded=1;whiteSpace=wrap;fillColor=#999999;fontColor=#ffffff;strokeColor=#666666;fontSize=11;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="430" y="80" width="300" height="100" as="geometry"/>
        </mxCell>

        <!-- SETAS: Usuários → Sistema -->
        <mxCell id="r1" value="Acessa via navegador web" style="edgeStyle=orthogonalEdgeStyle;fontSize=10;" edge="1" source="u_estudante" target="sys" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="r2" value="Gerencia turmas e atividades" style="edgeStyle=orthogonalEdgeStyle;fontSize=10;" edge="1" source="u_professor" target="sys" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="r3" value="Visualiza relatórios e painéis" style="edgeStyle=orthogonalEdgeStyle;fontSize=10;" edge="1" source="u_coordenador" target="sys" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="r4" value="Gerencia usuários e configurações" style="edgeStyle=orthogonalEdgeStyle;fontSize=10;" edge="1" source="u_admin" target="sys" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- SETAS: Sistema → Externos -->
        <mxCell id="r5" value="Envia notificações por e-mail" style="edgeStyle=orthogonalEdgeStyle;fontSize=10;dashed=1;" edge="1" source="sys" target="ext_email" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="r6" value="Faz upload/download de arquivos" style="edgeStyle=orthogonalEdgeStyle;fontSize=10;dashed=1;" edge="1" source="sys" target="ext_storage" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- LEGENDA -->
        <mxCell id="leg1" value="&lt;b&gt;Legenda:&lt;/b&gt; Azul escuro = Pessoa/Usuário | Azul claro = Sistema principal | Cinza = Sistema externo" style="text;fontSize=10;align=left;" vertex="1" parent="1">
          <mxGeometry x="60" y="760" width="700" height="30" as="geometry"/>
