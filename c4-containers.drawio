        </mxCell>

        <mxCell id="c_notif" value="&lt;b&gt;Serviço de Notificações&lt;/b&gt;&lt;br/&gt;[Container: Redis Pub/Sub]&lt;br/&gt;&lt;br/&gt;Recebe eventos e distribui notificações&lt;br/&gt;assíncronas (in-app e e-mail)." style="rounded=1;whiteSpace=wrap;fillColor=#1ba1e2;fontColor=#ffffff;strokeColor=#006EAF;fontSize=11;arcSize=10;" vertex="1" parent="1">
