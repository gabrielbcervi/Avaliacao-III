        <!-- CONTAINERS -->
        <mxCell id="c_frontend" value="&lt;b&gt;Aplicação Web (Frontend)&lt;/b&gt;&lt;br/&gt;[Container: React + TypeScript]&lt;br/&gt;&lt;br/&gt;Interface do usuário acessada via&lt;br/&gt;navegador. SPA (Single Page App)." style="rounded=1;whiteSpace=wrap;fillColor=#1ba1e2;fontColor=#ffffff;strokeColor=#006EAF;fontSize=11;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="300" y="160" width="240" height="130" as="geometry"/>
        </mxCell>

        <mxCell id="c_api" value="&lt;b&gt;API REST (Backend)&lt;/b&gt;&lt;br/&gt;[Container: Node.js + Express]&lt;br/&gt;&lt;br/&gt;Processa requisições, aplica regras&lt;br/&gt;de negócio e controle de acesso (RBAC)." style="rounded=1;whiteSpace=wrap;fillColor=#1ba1e2;fontColor=#ffffff;strokeColor=#006EAF;fontSize=11;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="600" y="280" width="260" height="130" as="geometry"/>
        </mxCell>

        <mxCell id="c_db" value="&lt;b&gt;Banco de Dados&lt;/b&gt;&lt;br/&gt;[Container: PostgreSQL]&lt;br/&gt;&lt;br/&gt;Armazena usuários, turmas, atividades,&lt;br/&gt;entregas e avaliações." style="shape=mxgraph.flowchart.database;whiteSpace=wrap;fillColor=#1ba1e2;fontColor=#ffffff;strokeColor=#006EAF;fontSize=11;" vertex="1" parent="1">
